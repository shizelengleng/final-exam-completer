{
  "name": "final-exam-completer",
  "version": "0.1.0",
  "description": "期末补完计划 - AI驱动的期末复习助手",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "vite --config vite.config.ts",
    "electron:build": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:win:portable": "vite build && electron-builder --win portable",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^5.4.0",
    "@cyntler/react-doc-viewer": "^1.17.1",
    "@tailwindcss/typography": "^0.5.20",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "antd": "^5.21.0",
    "cheerio": "^1.0.0",
    "docx": "^9.7.1",
    "duck-duck-scrape": "^2.2.7",
    "mammoth": "^1.8.0",
    "marked": "^14.0.0",
    "node-fetch": "^2.7.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.9.155",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0",
    "vis-data": "^8.0.3",
    "vis-network": "^10.1.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^32.3.3",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.41",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.finalexam.completer",
    "productName": "期末补完计划",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
